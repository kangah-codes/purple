{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "jsx": "react",
        "strict": true,
        "paths": {
            "@/*": ["./*"]
        },
        "noImplicitAny": false,
        "ignoreDeprecations": "6.0",
        "useUnknownInCatchVariables": false
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "purple/.expo/types/**/*.ts",
        "expo-env.d.ts",
        "purple/@types/**/*.d.ts",
        ".expo/types/**/*.ts"
    ]
}
