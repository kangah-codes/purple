{
    "build": {
        "production": {
            "developmentClient": false,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_KEY": "EXPO_PUBLIC_API_KEY",
                "EXPO_PUBLIC_API_URL": "EXPO_PUBLIC_API_URL"
            },
            "channel": "production",
            "environment": "production"
        },
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            },
            "env": {
                "EXPO_PUBLIC_API_KEY": "EXPO_PUBLIC_API_KEY",
                "EXPO_PUBLIC_API_URL": "EXPO_PUBLIC_API_URL"
            },
            "channel": "development",
            "environment": "development"
        },
        "rc": {
            "developmentClient": false,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_KEY": "EXPO_PUBLIC_API_KEY",
                "EXPO_PUBLIC_API_URL": "EXPO_PUBLIC_API_URL"
            },
            "channel": "rc",
            "environment": "production"
        }
    }
}
