            "node": "22.17.0"
        },
        "rc": {
            "developmentClient": false,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_KEY": "EXPO_PUBLIC_API_KEY",
                "EXPO_PUBLIC_API_URL": "EXPO_PUBLIC_API_URL",
                "EAS_BUILD_PROFILE": "rc"
            },
            "channel": "rc",
            "environment": "production",
            "node": "22.17.0"
