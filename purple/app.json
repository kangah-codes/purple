{
    "expo": {
        "name": "Purple",
        "slug": "purple",
        "version": "0.1.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "com.akangah89.Purple",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/images/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff",
            "width": 320,
            "height": 320
        },
        "assetBundlePatterns": ["**/*"],
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.akangah89.Purple"
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/images/adaptive-icon.png",
                "backgroundColor": "#9333EA"
            },
            "package": "com.akangah89.Purple"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-font",
                {
                    "fonts": [
                        "./assets/fonts/Suprapower.otf",
                        "./assets/fonts/InterDisplay-Thin.ttf",
                        "./assets/fonts/InterDisplay-Black.ttf",
                        "./assets/fonts/InterDisplay-Bold.ttf",
                        "./assets/fonts/InterDisplay-ExtraBold.ttf",
                        "./assets/fonts/InterDisplay-ExtraLight.ttf",
                        "./assets/fonts/InterDisplay-Light.ttf",
                        "./assets/fonts/InterDisplay-Medium.ttf",
                        "./assets/fonts/InterDisplay-Regular.ttf",
                        "./assets/fonts/InterDisplay-SemiBold.ttf",
                        "./assets/fonts/Wolf-Sans-Regular.ttf",
                        "./assets/fonts/Arial-Rounded-MT-Bold.ttf",
                        "./assets/fonts/gresa/Gresa-Regular.ttf",
                        "./assets/fonts/Mockup-Display.ttf",
                        "./assets/fonts/mona-sans/MonaSans-Black.ttf",
                        "./assets/fonts/mona-sans/MonaSans-Bold.ttf",
                        "./assets/fonts/mona-sans/MonaSans-ExtraBold.ttf",
                        "./assets/fonts/mona-sans/MonaSans-ExtraLight.ttf",
                        "./assets/fonts/mona-sans/MonaSans-Light.ttf",
                        "./assets/fonts/mona-sans/MonaSans-Medium.ttf",
                        "./assets/fonts/mona-sans/MonaSans-Regular.ttf",
                        "./assets/fonts/mona-sans/MonaSans-SemiBold.ttf"
                    ]
                }
            ],
            "expo-secure-store",
            [
                "expo-build-properties",
                {
                    "ios": {
                        "newArchEnabled": false
                    },
                    "android": {
                        "newArchEnabled": false
                    }
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "router": {
                "origin": false
            },
            "eas": {
                "projectId": "381fc979-2396-4f04-93f0-bdfea57f48d2"
            }
        },
        "owner": "akangah89"
    }
}
